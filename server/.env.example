PORT=3001
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
NODE_ENV=development
GOOGLE_SHEETS_DB_ENABLED=true
# Same spreadsheet mirrors JSON files (tabs like db_users). Set ID so users.json restores on deploy/clone.
GOOGLE_SHEETS_SPREADSHEET_ID=
# Prefer full JSON string in cloud env:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Or point to local key file path:
# GOOGLE_SERVICE_ACCOUNT_PATH=D:/path/to/google-service-account.json
# Parent folder for Drive uploads (student profiles + payment receipt folder NITA_Payment_Receipts)
GOOGLE_DRIVE_PARENT_FOLDER_ID=
# Optional: wallet QR images as Drive file share links (safer than serving from /public)
WALLET_QR_DRIVE_URL_PHONEPE=
WALLET_QR_DRIVE_URL_AMAZONPAY=
WALLET_QR_DRIVE_URL_PAYTM=
# users.json teacher id for legacy batch teacher "NILanchal25" and auto teacher class on wallet approval
DEFAULT_TEACHER_USER_ID=TCH-001
# Razorpay — course enrollment payments (https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
# From Razorpay Dashboard → Webhooks → your webhook → Secret (not the API secret)
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Admin alerts for online payments
ADMIN_NOTIFY_EMAIL=admin@nitaclasses.com
ADMIN_WHATSAPP=919986437890
PUBLIC_APP_URL=https://your-site.vercel.app

# Email (SMTP) — optional; used for admin + student enrollment emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=NITA Classes <your@gmail.com>
