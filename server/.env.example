PORT=3001
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
NODE_ENV=development
GOOGLE_SHEETS_DB_ENABLED=true
GOOGLE_SHEETS_SPREADSHEET_ID=
# Prefer full JSON string in cloud env:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Or point to local key file path:
# GOOGLE_SERVICE_ACCOUNT_PATH=D:/path/to/google-service-account.json
